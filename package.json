{
  "name": "FRNA2",
  "version": "0.0.3",
  "author": {
    "name": "Mahaman Lawali Inoussa / FUMA Gaskiya Maradi - Niger",
    "email": "mahamanlawali09@gmail.com",
    "url": "http://fumagaskiya.ne"
  },
  "homepage": "http://fumagaskiya.ne",
  "main": "electron/electron-starter.js",
  "build": {
    "appId": "com.fumagaskiya.frna2",
    "electronVersion": "4.2.3",
    "asar": true,
    "files": [
      "www/**/*",
      "assets/***/*",
      "electron/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "FUMA Gaskiya Maradi - Niger"
    },
    "nsis": {
      "perMachine": true,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "electron": "electron .",
    "ebuild": "node_modules/.bin/build",
    "electron-serve": "ng build --prod && electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "private": true,
  "dependencies": {
